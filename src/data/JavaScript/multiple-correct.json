    {
        "id": "js-multi-014",
        "type": "multiple-correct",
        "theme": "Type Checking & Arrays",
        "question": "Which of the following are valid ways to check if a value is an array?",
        "options": [
            {
                "id": "a",
                "text": "Array.isArray(value)"
            },
            {
                "id": "b",
                "text": "value instanceof Array"
            },
            {
                "id": "c",
                "text": "value.constructor === Array"
            },
            {
                "id": "d",
                "text": "Object.prototype.toString.call(value) === '[object Array]'"
            },
            {
                "id": "e",
                "text": "typeof value === 'array'"
            }
        ],
        "correctIds": [
            "a",
            "b",
            "c",
            "d"
        ],
        "explanation": "typeof never returns 'array'. All other methods can work, but Array.isArray() is the most reliable (handles cross-realm / iframes)."
    },
