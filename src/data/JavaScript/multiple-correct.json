            },
            {
                "id": "d",
                "text": "\" \" == 0"
            },
            {
                "id": "e",
                "text": "NaN == NaN"
            },
            {
                "id": "f",
                "text": "\"1\" == 1"
            }
        ],
        "correctIds": [
            "a",
            "b",
